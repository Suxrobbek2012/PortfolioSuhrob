generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String    @id @default(cuid())
  title       String
  description String
  longDesc    String?
  image       String?
  tags        String    // JSON array
  liveUrl     String?
  githubUrl   String?
  featured    Boolean   @default(false)
  order       Int       @default(0)
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  content   String
  approved  Boolean  @default(false)  // moderation
  createdAt DateTime @default(now())
}

model Skill {
  id       String @id @default(cuid())
  name     String
  level    Int
  category String
  icon     String?
  order    Int    @default(0)
}

model Experience {
  id          String  @id @default(cuid())
  title       String
  company     String
  location    String?
  startDate   String
  endDate     String?
  current     Boolean @default(false)
  description String
  order       Int     @default(0)
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String
  content   String
  tags      String
  published Boolean  @default(false)
  views     Int      @default(0)
  readTime  Int      @default(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String   // 'user' | 'assistant'
  content   String
  sessionId String
  createdAt DateTime @default(now())
}
